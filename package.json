{
  "name": "@itsapps/itsshops-core-back",
  "version": "1.0.12",
  "description": "",
  "keywords": [
    "sanity",
    "sanity-plugin"
  ],
  "license": "MIT",
  "author": "itsapps <dev@itsapps.at>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./external": {
      "source": "./src/external/index.ts",
      "import": "./dist/external/index.js",
      "default": "./dist/external/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./external": {
        "import": "./dist/external/index.js",
        "default": "./dist/external/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "browserslist": "extends @sanity/browserslist-config",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "sanity.json",
    "src",
    "v2-incompatible.js"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict",
    "prepare": "npm run build",
    "test": "vitest",
    "extract": "sanity schema extract --workspace de",
    "typegen": "sanity typegen generate",
    "start": "sanity dev --host 0.0.0.0 --port 3331"
  },
  "dependencies": {
    "@portabletext/block-tools": "^5.0.0",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.0.3",
    "@sanity/incompatible-plugin": "^1.0.5",
    "@sanity/locale-de-de": "^1.1.28",
    "@sanity/orderable-document-list": "^1.4.2",
    "@sanity/schema": "^5.5.0",
    "@sanity/vision": "^5.5.0",
    "countries-list": "^3.2.2",
    "flat": "^6.0.1",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^25.7.4",
    "lodash": "^4.17.23",
    "react-icons": "^5.6.0",
    "react-player": "^3.4.0",
    "sanity-plugin-dashboard-widget-document-list": "^2.1.3",
    "sanity-plugin-documents-pane": "^3.0.2",
    "sanity-plugin-internationalized-array": "4.0.1",
    "sanity-plugin-media": "^4.1.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sanity/pkg-utils": "^10.4.4",
    "@sanity/plugin-kit": "^4.0.20",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "babel-plugin-styled-components": "^2.1.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^19.1",
    "react-dom": "^19.1",
    "sanity": "^5.10.0",
    "styled-components": "^6.3.11"
  },
  "engines": {
    "node": ">=18"
  }
}
